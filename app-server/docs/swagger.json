                    {
                        "type": "boolean",
                        "description": "Сортировать по имени (не используется в usecase)",
                        "name": "name",
                        "in": "query"
                    },
                    {
                        "type": "boolean",
                        "description": "Сортировать по калориям (desc)",
                        "name": "calories",
                        "in": "query"
                    },
                    {
                        "type": "boolean",
                        "description": "Сортировать по белкам (desc)",
                        "name": "proteins",
                        "in": "query"
                    },
                    {
                        "type": "boolean",
                        "description": "Сортировать по жирам (desc)",
                        "name": "fats",
                        "in": "query"
                    },
                    {
                        "type": "boolean",
                        "description": "Сортировать по углеводам (desc)",
                        "name": "carbs",
                        "in": "query"
                    },
                    {
                        "type": "string",
